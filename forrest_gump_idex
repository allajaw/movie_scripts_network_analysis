  .force("link", d3.forceLink(rawEdges.map(e=>({...e,source:e.s,target:e.t})))
    .id(d=>d.id)
    .distance(d => 80 + 120 / (d.w||1))
    .strength(d => Math.min(0.8, 0.1 * d.w))
  )
  .force("charge", d3.forceManyBody().strength(-320))
  .force("center", d3.forceCenter(0, 0))
  .force("collision", d3.forceCollide().radius(d => nodeRadius(d) + 6))
  .alphaDecay(0.025);

// Build links array with source/target as IDs
const linkData = rawEdges.map(e => ({source: e.s, target: e.t, w: e.w}));

const wScale = d3.scaleLinear().domain([1, maxW]).range([0.5, 4]);
const opacScale = d3.scaleLinear().domain([1, maxW]).range([0.15, 0.75]);

const linkSel = g.append("g").attr("class","links")
  .selectAll("line")
  .data(linkData)
  .join("line")
  .attr("stroke", "#c4732a")
  .attr("stroke-width", d => wScale(d.w))
  .attr("stroke-opacity", d => opacScale(d.w));

// radius by metric
function nodeRadius(d) {
  const modeMap = {degree:"degree", betweenness:"betweenness", closeness:"closeness", pagerank:"pagerank"};
  const key = modeMap[activeMode];
  const vals = rawNodes.map(n => n[key]);
  const mn = Math.min(...vals), mx = Math.max(...vals);
  const norm = mx > mn ? (d[key] - mn) / (mx - mn) : 0.5;
  return 5 + norm * 22;
}

const nodeGroup = g.append("g").attr("class","nodes")
  .selectAll("g")
  .data(rawNodes)
  .join("g")
  .attr("class","node-g")
  .call(d3.drag()
    .on("start", dragStart)
    .on("drag", dragged)
    .on("end", dragEnd)
  )
  .on("mouseover", showTooltip)
  .on("mousemove", moveTooltip)
  .on("mouseout", hideTooltip)
  .on("click", onNodeClick);

const circles = nodeGroup.append("circle")
  .attr("r", d => nodeRadius(d))
  .attr("fill", d => d.color)
  .attr("stroke", "rgba(255,255,255,0.15)")
  .attr("stroke-width", 1)
  .attr("filter", "url(#nodeGlow)");

// Add glow filter to SVG defs
const defs = svg.append("defs");
const filter = defs.append("filter").attr("id","nodeGlow").attr("x","-40%").attr("y","-40%").attr("width","180%").attr("height","180%");
filter.append("feGaussianBlur").attr("stdDeviation","2.5").attr("result","blur");
const feMerge = filter.append("feMerge");
feMerge.append("feMergeNode").attr("in","blur");
feMerge.append("feMergeNode").attr("in","SourceGraphic");

const labels = nodeGroup.append("text")
  .attr("class", d => nodeRadius(d) > 14 ? "node-label large" : "node-label")
  .text(d => d.label)
  .attr("dy", d => nodeRadius(d) + 9);

simulation.on("tick", () => {
  linkSel
    .attr("x1", d => d.source.x)
    .attr("y1", d => d.source.y)
    .attr("x2", d => d.target.x)
    .attr("y2", d => d.target.y);
  nodeGroup.attr("transform", d => `translate(${d.x},${d.y})`);
});

// Initial zoom fit after sim settles
simulation.on("end", () => {
  const {w, h} = getSize();
  const xs = rawNodes.map(n=>n.x), ys = rawNodes.map(n=>n.y);
  const x0=Math.min(...xs)-60, x1=Math.max(...xs)+60;
  const y0=Math.min(...ys)-60, y1=Math.max(...ys)+60;
  const scale = Math.min(w/(x1-x0), h/(y1-y0), 1.4) * 0.85;
  const tx = w/2 - scale*(x0+x1)/2;
  const ty = h/2 - scale*(y0+y1)/2;
  svg.transition().duration(1200)
    .call(zoom.transform, d3.zoomIdentity.translate(tx,ty).scale(scale));
});

// ── Mode controls ──
document.querySelectorAll(".ctrl-btn").forEach(btn => {
  btn.addEventListener("click", () => {
    activeMode = btn.dataset.mode;
    document.querySelectorAll(".ctrl-btn").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
    circles.transition().duration(450)
      .attr("r", d => nodeRadius(d));
    labels
      .attr("class", d => nodeRadius(d) > 14 ? "node-label large" : "node-label")
      .attr("dy", d => nodeRadius(d) + 9);
    // update ranking
    renderRanking(activeRankTab);
  });
});

// ── Click node ──
let selectedNode = null;
function onNodeClick(event, d) {
  event.stopPropagation();
  if (selectedNode === d.id) {
    selectedNode = null;
    resetHighlight();
    showEmptyCard();
    return;
  }
  selectedNode = d.id;
  highlightNode(d);
  showNodeCard(d);
}
svg.on("click", () => { selectedNode = null; resetHighlight(); showEmptyCard(); });

function highlightNode(d) {
  const neighborIds = new Set([d.id]);
  linkData.forEach(e => {
    if (e.source.id === d.id || e.source === d.id) neighborIds.add(e.target.id || e.target);
    if (e.target.id === d.id || e.target === d.id) neighborIds.add(e.source.id || e.source);
  });
  nodeGroup.attr("opacity", n => neighborIds.has(n.id) ? 1 : 0.07);
  circles.attr("stroke", n => n.id === d.id ? "#f5f0e8" : "rgba(255,255,255,0.15)")
    .attr("stroke-width", n => n.id === d.id ? 2.5 : 1);
  linkSel.attr("stroke-opacity", e => {
    const sid = e.source.id || e.source, tid = e.target.id || e.target;
    return (sid === d.id || tid === d.id) ? 0.9 : 0.02;
  });
}
function resetHighlight() {
  nodeGroup.attr("opacity", 1);
  circles.attr("stroke","rgba(255,255,255,0.15)").attr("stroke-width",1);
  linkSel.attr("stroke-opacity", e => opacScale(e.w));
}

// ── Node card ──
function showEmptyCard() {
  const card = document.getElementById("node-card");
  card.className = "node-card empty";
  card.innerHTML = "<p>Kliknij postać<br>aby zobaczyć szczegóły</p>";
}
function showNodeCard(d) {
  const card = document.getElementById("node-card");
  card.className = "node-card";
  const comm = communityNames[d.mod] || `Społeczność ${d.mod}`;
  card.innerHTML = `
    <h3>${d.label}</h3>
    <span class="community-badge" style="background:${d.color}22;color:${d.color};border:1px solid ${d.color}44">${comm}</span>
    <div class="metrics-grid">
      <div class="metric-item">
        <div class="metric-label">Stopień (waga)</div>
        <div class="metric-value">${d.degree}</div>
      </div>
      <div class="metric-item">
        <div class="metric-label">Pośrednictwo</div>
        <div class="metric-value">${d.betweenness.toFixed(4)}</div>
      </div>
      <div class="metric-item">
        <div class="metric-label">Bliskość</div>
        <div class="metric-value">${d.closeness.toFixed(3)}</div>
      </div>
      <div class="metric-item">
        <div class="metric-label">PageRank</div>
        <div class="metric-value">${d.pagerank.toFixed(4)}</div>
      </div>
    </div>
  `;
}

// ── Tooltip ──
const tooltip = document.getElementById("tooltip");
function showTooltip(event, d) {
  tooltip.style.display = "block";
  tooltip.innerHTML = `
    <strong>${d.label}</strong>
    <div class="tt-row"><span class="tt-label">Stopień</span><span class="tt-val">${d.degree}</span></div>
    <div class="tt-row"><span class="tt-label">Pośrednictwo</span><span class="tt-val">${d.betweenness.toFixed(4)}</span></div>
    <div class="tt-row"><span class="tt-label">PageRank</span><span class="tt-val">${d.pagerank.toFixed(4)}</span></div>
  `;
}
function moveTooltip(event) {
  const x = event.clientX, y = event.clientY;
  tooltip.style.left = (x + 14) + "px";
  tooltip.style.top = (y - 10) + "px";
  if (x + 240 > window.innerWidth) tooltip.style.left = (x - 230) + "px";
}
function hideTooltip() { tooltip.style.display = "none"; }

// ── Drag ──
function dragStart(event, d) {
  if (!event.active) simulation.alphaTarget(0.3).restart();
  d.fx = d.x; d.fy = d.y;
}
function dragged(event, d) { d.fx = event.x; d.fy = event.y; }
function dragEnd(event, d) {
  if (!event.active) simulation.alphaTarget(0);
  d.fx = null; d.fy = null;
}

// ══════════════════════════════════════════════════════════
//  COMMUNITY LEGEND
// ══════════════════════════════════════════════════════════
const legendList = document.getElementById("legend-list");
Object.entries(communityNames).forEach(([k,name]) => {
  const div = document.createElement("div");
  div.className = "legend-item";
  div.innerHTML = `<span class="legend-dot" style="background:${communityColors[k]}"></span><span>${name}</span>`;
  legendList.appendChild(div);
});

// ══════════════════════════════════════════════════════════
//  RANKING
// ══════════════════════════════════════════════════════════
let activeRankTab = "degree";
const rankMetrics = {degree:"degree", betweenness:"betweenness", closeness:"closeness", pagerank:"pagerank"};

function renderRanking(metric) {
  const list = document.getElementById("ranking-list");
  const key = rankMetrics[metric];
  const sorted = [...rawNodes].sort((a,b) => b[key] - a[key]).slice(0, 30);
  const maxVal = sorted[0][key] || 1;
  list.innerHTML = "";
  sorted.forEach((d, i) => {
    const div = document.createElement("div");
    div.className = "rank-item";
    const pct = Math.max(4, (d[key] / maxVal) * 100);
    div.innerHTML = `
      <span class="rank-num">${i+1}</span>
      <span class="rank-dot" style="background:${d.color}"></span>
      <span class="rank-name" title="${d.label}">${d.label}</span>
      <span class="rank-bar-wrap"><span class="rank-bar" style="width:${pct}%;background:${d.color}"></span></span>
    `;
    div.addEventListener("click", () => {
      const node = rawNodes.find(n => n.id === d.id);
      if (node) {
        selectedNode = node.id;
        highlightNode(node);
        showNodeCard(node);
        // pan to node
        const {w,h} = getSize();
        svg.transition().duration(600)
          .call(zoom.transform, d3.zoomIdentity
            .translate(w/2 - node.x, h/2 - node.y)
            .scale(1.5));
      }
    });
    list.appendChild(div);
  });
}
renderRanking("degree");

document.querySelectorAll(".tab-btn").forEach(btn => {
  btn.addEventListener("click", () => {
    activeRankTab = btn.dataset.rank;
    document.querySelectorAll(".tab-btn").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
    renderRanking(activeRankTab);
  });
});

// ── Resize ──
window.addEventListener("resize", () => {
  const {w,h} = getSize();
  simulation.force("center", d3.forceCenter(0,0));
});
</script>
</body>
</html>
