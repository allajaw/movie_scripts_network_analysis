// simple closeness (1 / avg_path approximated via BFS)
function computeCloseness(nodes, edges) {
  const adj = {};
  nodes.forEach(n => adj[n.id] = []);
  edges.forEach(e => {
    if (adj[e.s]) adj[e.s].push(e.t);
    if (adj[e.t]) adj[e.t].push(e.s);
  });
  const result = {};
  nodes.forEach(src => {
    const visited = {[src.id]: 0};
    const queue = [src.id];
    while (queue.length) {
      const cur = queue.shift();
      (adj[cur] || []).forEach(nb => {
        if (!(nb in visited)) { visited[nb] = visited[cur] + 1; queue.push(nb); }
      });
    }
    const total = Object.values(visited).reduce((a,b)=>a+b,0);
    result[src.id] = total > 0 ? (Object.keys(visited).length - 1) / total : 0;
  });
  return result;
}

// pagerank simple iteration
function computePageRank(nodes, edges, iter=30, d=0.85) {
  const N = nodes.length;
  const pr = {};
  const outSum = {};
  nodes.forEach(n => { pr[n.id] = 1/N; outSum[n.id] = 0; });
  edges.forEach(e => { outSum[e.s] = (outSum[e.s]||0) + e.w; outSum[e.t] = (outSum[e.t]||0) + e.w; });
  for (let i = 0; i < iter; i++) {
    const newPr = {};
    nodes.forEach(n => newPr[n.id] = (1-d)/N);
    edges.forEach(e => {
      if (outSum[e.s]) newPr[e.t] = (newPr[e.t]||0) + d * pr[e.s] * (e.w / outSum[e.s]);
      if (outSum[e.t]) newPr[e.s] = (newPr[e.s]||0) + d * pr[e.t] * (e.w / outSum[e.t]);
    });
    Object.assign(pr, newPr);
  }
  return pr;
}

